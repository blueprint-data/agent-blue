# Docker Compose sandbox orchestration variables
# Use `docker compose --env-file .env.sandbox -f docker-compose.sandbox.yml ...`
#
# Fast local shortcut (reuse existing `.env` values):
# npm run sandbox:local
# (equivalent raw command shown below)
# AGENT_BLUE_ENV_FILE=.env SANDBOX_DOMAIN=localhost SANDBOX_HTTP_PORT=8080 SANDBOX_HTTPS_PORT=8443 \
# docker compose --env-file .env -f docker-compose.sandbox.yml up -d --build proxy admin slack
#
# Add `telegram` to the services list only if you already have TELEGRAM_BOT_TOKEN configured.
SANDBOX_DOMAIN=sandbox.agent.blueprintdata.xyz
SANDBOX_HTTP_PORT=80
SANDBOX_HTTPS_PORT=443
APP_DATA_DIR=/app/data

# LLM provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
AGENT_VERBOSE=false

# Optional global Snowflake defaults.
# If you configure warehouse credentials per tenant in the Admin UI,
# only keep the shared values you actually want as fallbacks.
SNOWFLAKE_AUTH_TYPE=password
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=
SNOWFLAKE_SDK_LOG_LEVEL=OFF

# Slack Events API service
# Use a dedicated Slack app/workspace for sandbox.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_PORT=3000
SLACK_DEFAULT_TENANT_ID=
SLACK_DEFAULT_PROFILE_NAME=default
SLACK_TEAM_TENANT_MAP=
SLACK_OWNER_TEAM_IDS=
SLACK_OWNER_ENTERPRISE_IDS=
SLACK_STRICT_TENANT_ROUTING=true

# Scheduler (cron cadence is UTC unless overridden)
SCHEDULER_TIMEZONE=UTC
SCHEDULER_REFRESH_INTERVAL_MS=60000

# Telegram bot (long polling)
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT_ID=
TELEGRAM_DEFAULT_PROFILE_NAME=default

# Admin UI and API
ADMIN_PORT=3100
ADMIN_USERNAME=admin
# If you paste a generated scrypt hash here, wrap it in single quotes so Docker Compose
# does not try to treat the `$...` segments as variable interpolation.
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=12
ADMIN_UI_TOKEN=
ADMIN_BEARER_TOKEN=
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=
