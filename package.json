{
  "name": "agent-blue",
  "version": "1.0.0",
  "description": "Analytics agent platform with Snowflake + dbt support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run admin:web:build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:admin": "node dist/index.js admin-ui",
    "start:slack": "node dist/index.js slack",
    "check": "tsc -p tsconfig.json --noEmit && npm run admin:web:check",
    "slack:server": "npm run dev -- slack --profile default --port 3000",
    "tunnel": "cloudflared tunnel --loglevel warn --transport-loglevel warn --config cloudflared-agent-blue.yml run agent-blue-slack",
    "slack:local": "concurrently -k -n tunnel,slack -c cyan,green \"npm run tunnel\" \"npm run slack:server\"",
    "admin:ui": "npm run dev -- admin-ui",
    "admin:api": "npm run dev -- admin-ui",
    "admin:web:dev": "vite --config admin-ui/vite.config.ts",
    "admin:web:build": "vite build --config admin-ui/vite.config.ts",
    "admin:web:check": "tsc -p admin-ui/tsconfig.json --noEmit",
    "admin:dev": "concurrently -k -n api,web,tunnel -c green,cyan,magenta \"npm run admin:api\" \"npm run admin:web:dev\" \"npm run tunnel\"",
    "deploy": "sh -lc 'ssh -i \"$HOME/.ssh/DO\" root@5.78.178.31 \"cd /root/agent-blue && git pull && docker compose up -d --build && docker image prune -f && docker builder prune -f\"'",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mporracindie/agent-blue.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mporracindie/agent-blue/issues"
  },
  "homepage": "https://github.com/mporracindie/agent-blue#readme",
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "grammy": "^1.41.1",
    "multer": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "snowflake-sdk": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
