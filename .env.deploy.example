APP_DATA_DIR=/app/data

# LLM provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
AGENT_VERBOSE=false

# Optional global Snowflake defaults.
# If you configure warehouse credentials per tenant in the Admin UI,
# only keep the shared values you actually want as fallbacks.
SNOWFLAKE_AUTH_TYPE=password
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=
SNOWFLAKE_SDK_LOG_LEVEL=OFF

# Slack Events API service
# Global app (optional): POST /slack/events — set BOTH token and secret, or omit BOTH to use only per-tenant apps.
# Per-tenant Slack apps (optional): configure each Slack app’s Request URL as
#   https://<your-public-host>:<SLACK_PORT>/slack/events/tenants/<tenantId>
# (tenant id must match the tenant in Admin UI). Store bot token + signing secret per tenant in the UI; they are never returned by the API.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_PORT=3000
SLACK_DEFAULT_TENANT_ID=
SLACK_DEFAULT_PROFILE_NAME=default
SLACK_TEAM_TENANT_MAP=
SLACK_OWNER_TEAM_IDS=
SLACK_OWNER_ENTERPRISE_IDS=
SLACK_STRICT_TENANT_ROUTING=false

# Telegram bot (long polling)
# TELEGRAM_BOT_TOKEN is the optional global bot. Tenants can also have their own token in Admin UI; the telegram
# process starts one long-poll loop per distinct token (global + each tenant override).
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT_ID=
TELEGRAM_DEFAULT_PROFILE_NAME=default

# Admin UI and API
ADMIN_PORT=3100
ADMIN_USERNAME=admin
# If you paste a generated scrypt hash here, wrap it in single quotes so Docker Compose
# does not try to treat the `$...` segments as variable interpolation.
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=12
ADMIN_UI_TOKEN=
ADMIN_BEARER_TOKEN=
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=
